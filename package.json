{
  "name": "tasklr",
  "version": "1.0.0",
  "description": "A web-based task management app using Google Tasks API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "smoke-export": "node scripts/smoke_export_checkdeps.js",
    "smoke-export-local": "node scripts/smoke_export_local_test.js",
    "test:filename-parsing": "node scripts/test_filename_parsing.js",
    "test": "node scripts/test_filename_parsing.js && node scripts/test_include_hash_in_reauth.js",
    "test:auth-refresh": "node scripts/test_auth_refresh.js",
    "test:ci": "npm run test && npm run test:validate-env && npm run smoke-export-local && npm run test:auth-refresh && npm run check:syntax",
    "validate-env": "node scripts/validate_oauth_env.js",
    "test:validate-env": "node scripts/test_validate_env.js",
    "gen-secret": "node scripts/generate_session_secret.js",
    "test:quick": "npm run test:filename-parsing && npm run test:validate-env",
    "check:syntax": "node --check server.js",
    "test:api-me": "node scripts/test_api_me.js",
    "smoke:api-me": "bash scripts/smoke-api-me.sh",
    "test:include-reauth-hash": "node scripts/test_include_hash_in_reauth.js",
    "test:integration": "node scripts/test_integration_routes.js",
    "test:local": "npm run check:syntax && npm test",
    "smoke-status-health": "node scripts/smoke_status_health_checkdeps.js",
    "test:status": "node scripts/test_status.js",
    "check:endpoints": "node scripts/check_endpoints.js",
    "check:export": "node scripts/check_export_filename.js",
    "test:depfree": "node --check server.js && npm run test:quick",
    "test:health": "node scripts/test_health.js",
    "smoke:depfree": "node scripts/smoke_depfree_runner.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "googleapis": "^144.0.0",
    "session-file-store": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
