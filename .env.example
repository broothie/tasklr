GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SESSION_SECRET=a-long-random-string
PORT=3000
BASE_URL=http://localhost:3000

# Optional developer/test flags
# Set to 1 to enable test-only routes used by local smoke tests
ALLOW_TEST_ROUTES=0

# When set to 1 (or true) the `scripts/validate_oauth_env.js` script will
# exit non-zero if `SESSION_SECRET` is shorter than 16 characters. Useful
# to enforce stronger secrets in CI.
FAIL_ON_WEAK_SESSION_SECRET=0

# Readiness probe controls (used by server.js readiness checks)
# Set to 1 to enable Google API checks during readiness probing
READINESS_CHECK_GOOGLE=0
# If the readiness probe needs an auth refresh token to be present set this
# to 1 as well (requires a valid refresh token in session during the check)
READINESS_CHECK_GOOGLE_AUTH_REFRESH_TOKEN=0
